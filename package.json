{
  "name": "gromai-app",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "build": "electron-builder --win"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gromhorse.gromai",
