{
  "name": "gromai-app",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "build": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gromhorse.gromai",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico",
      "artifactName": "GromAI Premium.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.ico",
      "artifactName": "GromAI Premium.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.ico",
      "artifactName": "GromAI Premium.${ext}"
    }
  }
}
